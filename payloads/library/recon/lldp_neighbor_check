#!/bin/bash
# Title: LLDP Neighbor Check
# Author: Hak5Darren
# Props: Korben
# Description: Checks for an LLDP Neighbor

LED SETUP
LOOT_DIR=/root/loot/lldp_neighbor
mkdir -p $LOOT_DIR
COUNT=$(($(ls -l $LOOT_DIR/*.txt | wc -l)+1))
LOOT_FILE="$LOOT_DIR/lldp-$COUNT.txt"

TIMEOUT=60
source /usr/lib/list_tools

initialize_menu() {
  ADD_MENU_ITEM "Start" "lldp_check"
  ADD_MENU_ITEM "Options" "menu_options"
  ADD_MENU_ITEM "Quit" "EXIT_MENU"
  ADD_SUBMENU_ITEM "menu_options" "Set Timeout" "set_timeout"
  ADD_SUBMENU_ITEM "menu_options" "Done" "show_options"
}


set_timeout(){
  TIMEOUT="$(SINGLE_NUMBER_PICKER "Timeout Seconds" "60" "30")"
}
show_options(){ 
  ALERT "Timeout:\n$TIMEOUT\n\nPress a key." -1 false true; SELECT_MENU main_menu
}

lldp_check(){
  source /usr/lib/spinner_tools
  CREATE_SPINNER "Starting DHCP"
    NETMODE DHCP_CLIENT
  STOP_SPINNER
  WAIT_FOR_LINK
  WAIT_FOR_IP
  CREATE_SPINNER "Test $COUNT Waiting ${TIMEOUT}s for LLDP"
    elapsed=0
    while [ "$elapsed" -lt "$TIMEOUT" ]; do
      dash_count="$(lldpctl | grep '^-*-$' | wc -l)"
      if [ "$dash_count" -eq 3 ]; then
        LED FINISH
        lldpctl -f keyvalue | sed 's/lldp.eth0.//g' > $LOOT_FILE
        break
      fi
      sleep 1 && elapsed=$((elapsed + 1))
    done
  STOP_SPINNER
  if [ "$elapsed" -ge "$TIMEOUT" ]; then
    LED FAIL
    SCREEN_WRITE "LLDP Neighbor"
    SCREEN_WRITE "Not Found"
  fi
  if [ -f "$LOOT_FILE" ]; then
    RESP="$(OPTION_DIALOG "Neighbor Found. View Results?" "Basic" "Full")"
      case $RESP in
        "Basic") basic_results ;;
        "Full") full_results ;;
      esac
  fi
  exit
}

basic_results(){
  SCREEN_WRITE "$(cat $LOOT_FILE | grep "via=" | sed 's/via=//g')"
  SCREEN_WRITE "$(cat $LOOT_FILE | grep "chassis.local=" | sed 's/chassis.local=//g')"
  SCREEN_WRITE "$(cat $LOOT_FILE | grep "port.ifname=" | sed 's/port.ifname=//g')"
  SCREEN_WRITE "TTL: $(cat $LOOT_FILE | grep "port.ttl=" | sed 's/port.ttl=//g')"
}

full_results(){
  CLEAR_MENU "results"
  source /usr/lib/spinner_tools
  CREATE_SPINNER "Loading..."
  RESULTS="$(cat $LOOT_FILE | grep -v 'chassis.descr')"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    key="$(echo $line | awk -F= '{print $1}')"
    value="$(echo $line | awk -F= '{print $2}')"
    logger -t "lldp=payload" "KEY: $key"
    logger -t "lldp=payload" "VALUE: $value"
    ADD_SUBMENU_ITEM "results" "$key" "results_menu_${key}"
    ADD_SUBMENU_ITEM "results_menu_${key}" "$value" "noop"
    ADD_SUBMENU_ITEM "results_menu_${key}" "Back" "Back"
  done <<< "$RESULTS"
  ADD_SUBMENU_ITEM "results" "Back" "Back"
  STOP_SPINNER
  SELECT_MENU results
}


initialize_menu
START_MENU
